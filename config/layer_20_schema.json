{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://spse.local/schemas/layer_20_schema.json",
  "title": "Layer20TestObservation",
  "type": "object",
  "required": [
    "timestamp",
    "test_id",
    "query",
    "total_latency_ms",
    "layer_2_time_ms",
    "layer_5_routing_time_ms",
    "layer_9_decision_time_ms",
    "layer_11_retrieval_time_ms",
    "layer_13_merge_time_ms",
    "layer_14_scoring_time_ms",
    "layer_16_resolution_time_ms",
    "units_discovered",
    "units_activated",
    "new_units_created",
    "units_pruned",
    "memory_delta_kb",
    "episodic_count",
    "core_count",
    "anchors_protected",
    "retrieval_triggered",
    "sources_consulted",
    "evidence_merged",
    "candidates_scored",
    "top_candidate_score",
    "final_answer_confidence",
    "config_values_used"
  ],
  "properties": {
    "timestamp": { "type": "string" },
    "test_id": { "type": "string" },
    "query": { "type": "string" },
    "total_latency_ms": { "type": "integer", "minimum": 0 },
    "layer_2_time_ms": { "type": "integer", "minimum": 0 },
    "layer_5_routing_time_ms": { "type": "integer", "minimum": 0 },
    "layer_9_decision_time_ms": { "type": "integer", "minimum": 0 },
    "layer_11_retrieval_time_ms": { "type": "integer", "minimum": 0 },
    "layer_13_merge_time_ms": { "type": "integer", "minimum": 0 },
    "layer_14_scoring_time_ms": { "type": "integer", "minimum": 0 },
    "layer_16_resolution_time_ms": { "type": "integer", "minimum": 0 },
    "units_discovered": { "type": "integer", "minimum": 0 },
    "units_activated": { "type": "integer", "minimum": 0 },
    "new_units_created": { "type": "integer", "minimum": 0 },
    "units_pruned": { "type": "integer", "minimum": 0 },
    "memory_delta_kb": { "type": "integer" },
    "episodic_count": { "type": "integer", "minimum": 0 },
    "core_count": { "type": "integer", "minimum": 0 },
    "anchors_protected": { "type": "integer", "minimum": 0 },
    "retrieval_triggered": { "type": "boolean" },
    "retrieval_reason": { "type": ["string", "null"] },
    "sources_consulted": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_merged": { "type": "integer", "minimum": 0 },
    "candidates_scored": { "type": "integer", "minimum": 0 },
    "top_candidate_score": { "type": "number" },
    "score_breakdown": {
      "type": ["object", "null"],
      "required": [
        "spatial_fit",
        "context_fit",
        "sequence_fit",
        "transition_fit",
        "utility_fit",
        "confidence_fit",
        "evidence_support"
      ],
      "properties": {
        "spatial_fit": { "type": "number" },
        "context_fit": { "type": "number" },
        "sequence_fit": { "type": "number" },
        "transition_fit": { "type": "number" },
        "utility_fit": { "type": "number" },
        "confidence_fit": { "type": "number" },
        "evidence_support": { "type": "number" }
      }
    },
    "final_answer_confidence": { "type": "number" },
    "config_values_used": {
      "type": "object",
      "required": [
        "entropy_threshold",
        "retrieve_threshold",
        "recency_threshold_hours",
        "w_entropy",
        "w_recency",
        "w_disagreement",
        "w_cost",
        "w_spatial",
        "w_context",
        "w_sequence",
        "w_transition",
        "w_utility",
        "w_confidence",
        "w_evidence",
        "selection_temperature",
        "min_confidence_floor",
        "max_query_expansion_terms",
        "max_retrieval_results",
        "retrieval_timeout_ms"
      ],
      "properties": {
        "entropy_threshold": { "type": "number" },
        "retrieve_threshold": { "type": "number" },
        "recency_threshold_hours": { "type": "integer" },
        "w_entropy": { "type": "number" },
        "w_recency": { "type": "number" },
        "w_disagreement": { "type": "number" },
        "w_cost": { "type": "number" },
        "w_spatial": { "type": "number" },
        "w_context": { "type": "number" },
        "w_sequence": { "type": "number" },
        "w_transition": { "type": "number" },
        "w_utility": { "type": "number" },
        "w_confidence": { "type": "number" },
        "w_evidence": { "type": "number" },
        "selection_temperature": { "type": "number" },
        "min_confidence_floor": { "type": "number" },
        "max_query_expansion_terms": { "type": "integer" },
        "max_retrieval_results": { "type": "integer" },
        "retrieval_timeout_ms": { "type": "integer" }
      }
    }
  }
}
